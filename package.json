{
  "name": "dtc-elock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9 <23"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:railway": "node scripts/start-railway.mjs",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs scripts/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@zxing/browser": "0.2.1",
    "@zxing/library": "0.23.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dexie": "^4.0.8",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-auth": "^4.24.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-custom-error": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "fake-indexeddb": "^6.0.0",
    "sharp": "^0.35.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  }
}
