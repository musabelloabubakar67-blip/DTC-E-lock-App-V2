{
  "name": "dtc-elock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9 <23"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:railway": "node scripts/start-railway.mjs",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs scripts/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@zxing/browser": "0.1.5",
    "@zxing/library": "0.21.3",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "dexie": "^4.0.8",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.468.0",
    "next": "15.5.20",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-custom-error": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "fake-indexeddb": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  }
}
