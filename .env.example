# --- Database ---
DATABASE_PATH=./data/dtc-elock.sqlite

# --- Auth (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Seeding (Phase 0) ---
# Shared temp password for all seeded users. Rotate per-user post-launch.
SEED_USER_PASSWORD=changeme123

# --- Backup / restore (Cloudflare R2 via rclone) ---
R2_RCLONE_REMOTE=r2
R2_BUCKET=dtc-elock-backups
BACKUP_RETENTION_DAYS=30
