# --- Database ---
DATABASE_PATH=./data/dtc-elock.sqlite

# --- Auth (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-at-least-32-random-characters

# --- Seeding (Phase 0) ---
# Shared temporary password for local seeding only. Use at least 12 characters,
# then rotate every account before any real deployment.
SEED_USER_PASSWORD=

# --- Backup / restore (Cloudflare R2 via rclone) ---
R2_RCLONE_REMOTE=r2
R2_BUCKET=dtc-elock-backups
BACKUP_RETENTION_DAYS=30
